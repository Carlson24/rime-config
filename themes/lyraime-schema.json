{
  "$id": "https://github.com/Carlson24/LyraIME/blob/lyraime/doc/trime-schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JSON schema for LyraIME theme configuration",
  "definitions": {
    "ToolBar.Button.Background": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "default": "rectangle"
        },
        "corner_radius": {
          "type": "number",
          "default": 10
        },
        "normal": {
          "type": "string",
          "default": ""
        },
        "highlight": {
          "type": "string",
          "default": ""
        },
        "vertical_inset": {
          "type": "integer",
          "default": 4
        },
        "horizontal_inset": {
          "type": "integer",
          "default": 4
        }
      }
    },
    "ToolBar.Button.Foreground": {
      "type": "object",
      "properties": {
        "style": {
          "type": "string",
          "default": ""
        },
        "option_styles": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "normal": {
          "type": "string",
          "default": ""
        },
        "highlight": {
          "type": "string",
          "default": ""
        },
        "font_size": {
          "type": "number",
          "default": 18
        },
        "padding": {
          "type": "integer",
          "default": 4
        }
      }
    },
    "ToolBar.Button": {
      "type": "object",
      "properties": {
        "background": {
          "$ref": "#/definitions/ToolBar.Button.Background"
        },
        "foreground": {
          "$ref": "#/definitions/ToolBar.Button.Foreground"
        },
        "action": {
          "type": "string",
          "default": ""
        },
        "long_press_action": {
          "type": "string",
          "default": ""
        },
        "size": {
          "type": "array",
          "items": { "type": "integer" },
          "default": []
        }
      }
    },
    "colorValue": {
      "oneOf": [
        { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        { "type": "string", "pattern": "^0x[0-9a-fA-F]{1,8}$" }
      ]
    }
  },
  "type": "object",
  "properties": {
    "config_version": {
      "type": "string",
      "pattern": "\\d+(\\.\\d+)*",
      "description": "config version"
    },
    "name": {
      "type": "string",
      "description": "主题名称"
    },
    "author": {
      "type": "string",
      "description": "作者信息"
    },
    "style": {
      "type": "object",
      "properties": {
        "auto_caps": { "type": "boolean", "default": false },
        "background_folder": { "type": "string", "default": "backgrounds" },
        "candidate_border": { "type": "integer", "default": 0 },
        "candidate_border_round": { "type": "number", "default": 0 },
        "candidate_corner_radius": { "type": "number", "default": 5 },
        "candidate_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "candidate_padding": { "type": "integer", "default": 0 },
        "candidate_spacing": { "type": "number", "default": 0 },
        "candidate_text_size": { "type": "number", "default": 15 },
        "candidate_text_vertical_bias": { "type": "number", "default": 1 },
        "candidate_view_height": { "type": "integer", "default": 28 },
        "clipboard_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "clipboard_category_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "clipboard_category_text_size": { "type": "number", "default": 13 },
        "clipboard_text_size": { "type": "number", "default": 14 },
        "comment_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "comment_height": { "type": "integer", "default": 12 },
        "comment_position": { "enum": ["right", "top", "overlay"], "default": "right" },
        "comment_text_size": { "type": "number", "default": 10 },
        "comment_vertical_bias": { "type": "number", "default": 0 },
        "display_variants": { "type": "object", "additionalProperties": { "type": "string" }, "default": {} },
        "enter_label_mode": { "type": "integer", "minimum": 0, "maximum": 3, "default": 0 },
        "enter_labels": {
          "type": "object",
          "properties": {
            "go": { "type": "string", "default": "go" },
            "done": { "type": "string", "default": "done" },
            "next": { "type": "string", "default": "next" },
            "pre": { "type": "string", "default": "pre" },
            "search": { "type": "string", "default": "search" },
            "send": { "type": "string", "default": "send" },
            "default": { "type": "string", "default": "default" }
          }
        },
        "font_variations": { "type": "object", "additionalProperties": { "type": "boolean" }, "default": {} },
        "hanb_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "hint_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "hint_text_size": { "type": "number", "default": 0 },
        "horizontal_gap": { "type": "integer", "default": 0 },
        "key_border": { "type": "integer", "default": 0 },
        "key_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "key_hint_offset_x": { "type": "number", "default": 0 },
        "key_hint_offset_y": { "type": "number", "default": 0 },
        "key_long_text_size": { "type": "number", "default": 15 },
        "key_press_offset_x": { "type": "number", "default": 0 },
        "key_press_offset_y": { "type": "number", "default": 0 },
        "key_symbol_offset_x": { "type": "number", "default": 0 },
        "key_symbol_offset_y": { "type": "number", "default": 0 },
        "key_text_offset_x": { "type": "number", "default": 0 },
        "key_text_offset_y": { "type": "number", "default": 0 },
        "key_text_size": { "type": "number", "default": 15 },
        "keyboard_height": { "type": "integer", "default": 0 },
        "keyboard_height_land": { "type": "integer", "default": 0 },
        "keyboard_padding": { "type": "integer", "default": 0 },
        "keyboard_padding_bottom": { "type": "integer", "default": 0 },
        "keyboard_padding_land": { "type": "integer", "default": 0 },
        "keyboard_padding_land_bottom": { "type": "integer", "default": 0 },
        "keyboard_padding_top": { "type": "integer", "default": 0 },
        "label_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "label_text_size": { "type": "number", "default": 0 },
        "latin_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "popup_bottom_margin": { "type": "integer", "default": 0 },
        "popup_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "popup_height": { "type": "integer", "default": 0 },
        "popup_key_height": { "type": "integer", "default": 0 },
        "popup_text_size": { "type": "number", "default": 0 },
        "popup_width": { "type": "integer", "default": 0 },
        "reset_ascii_mode_on_focus_change": { "type": "boolean", "default": false },
        "round_corner": { "type": "number", "default": 0 },
        "shadow_radius": { "type": "number", "default": 0 },
        "symbol_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "symbol_text_size": { "type": "number", "default": 0 },
        "t9_side_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "t9_side_round_corner": { "type": "number", "default": -1 },
        "t9_side_text_size": { "type": "number", "default": -1 },
        "text_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "vertical_gap": { "type": "integer", "default": 0 }
      }
    },
    "preedit": {
      "type": "object",
      "properties": {
        "horizontal_padding": { "type": "integer", "default": 8 },
        "top_end_radius": { "type": "number", "default": 0 },
        "alpha": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 },
        "foreground": {
          "type": "object",
          "properties": {
            "font_size": { "type": "number", "default": 16 }
          }
        }
      }
    },
    "window": {
      "type": "object",
      "properties": {
        "insets": {
          "type": "object",
          "properties": {
            "vertical": { "type": "integer", "default": 0 },
            "horizontal": { "type": "integer", "default": 0 }
          }
        },
        "item_padding": {
          "type": "object",
          "properties": {
            "vertical": { "type": "integer", "default": 0 },
            "horizontal": { "type": "integer", "default": 0 }
          }
        },
        "min_width": { "type": "integer", "default": 0 },
        "corner_radius": { "type": "number", "default": 0 },
        "border": { "type": "integer", "default": 0 },
        "shadow": { "type": "number", "default": 0 },
        "alpha": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "foreground": {
          "type": "object",
          "properties": {
            "label_font_size": { "type": "number", "default": 20 },
            "text_font_size": { "type": "number", "default": 20 },
            "comment_font_size": { "type": "number", "default": 20 }
          }
        }
      }
    },
    "tool_bar": {
      "type": "object",
      "properties": {
        "back_style": { "type": "string", "default": "ic@arrow-left" },
        "button_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "primary_button": { "$ref": "#/definitions/ToolBar.Button" },
        "buttons": {
          "type": "array",
          "items": { "$ref": "#/definitions/ToolBar.Button" },
          "default": []
        }
      }
    },
    "candidates_tool": {
      "type": "object",
      "properties": {
        "nav_width": { "type": "integer", "default": 44 },
        "popup_width": { "type": "integer", "default": 0 },
        "popup_text_size": { "type": "number", "default": 0 },
        "popup_text_color": { "type": "string", "default": "" },
        "popup_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "background": { "type": "string", "default": "" },
        "separator_color": { "type": "string", "default": "" },
        "button_font": { "type": "array", "items": { "type": "string" }, "default": [] },
        "buttons": {
          "type": "array",
          "items": { "$ref": "#/definitions/ToolBar.Button" },
          "default": []
        },
        "popup": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string", "default": "" },
              "label": { "type": "string", "default": "" }
            }
          },
          "default": []
        }
      }
    },
    "fallback_colors": {
      "type": "object",
      "properties": {
        "candidate_text_color": { "type": "string", "default": "text_color" },
        "comment_text_color": { "type": "string", "default": "candidate_text_color" },
        "border_color": { "type": "string", "default": "back_color" },
        "candidate_separator_color": { "type": "string", "default": "border_color" },
        "hilited_text_color": { "type": "string", "default": "text_color" },
        "hilited_back_color": { "type": "string", "default": "back_color" },
        "hilited_candidate_text_color": { "type": "string", "default": "hilited_text_color" },
        "hilited_candidate_back_color": { "type": "string", "default": "hilited_back_color" },
        "hilited_label_color": { "type": "string", "default": "hilited_candidate_text_color" },
        "hilited_comment_text_color": { "type": "string", "default": "comment_text_color" },
        "hilited_key_back_color": { "type": "string", "default": "hilited_candidate_back_color" },
        "hilited_key_text_color": { "type": "string", "default": "hilited_candidate_text_color" },
        "hilited_key_symbol_color": { "type": "string", "default": "hilited_comment_text_color" },
        "hilited_off_key_back_color": { "type": "string", "default": "hilited_key_back_color" },
        "hilited_on_key_back_color": { "type": "string", "default": "hilited_key_back_color" },
        "hilited_off_key_text_color": { "type": "string", "default": "hilited_key_text_color" },
        "hilited_on_key_text_color": { "type": "string", "default": "hilited_key_text_color" },
        "key_back_color": { "type": "string", "default": "back_color" },
        "key_border_color": { "type": "string", "default": "border_color" },
        "key_text_color": { "type": "string", "default": "candidate_text_color" },
        "key_symbol_color": { "type": "string", "default": "comment_text_color" },
        "label_color": { "type": "string", "default": "candidate_text_color" },
        "off_key_back_color": { "type": "string", "default": "key_back_color" },
        "off_key_text_color": { "type": "string", "default": "key_text_color" },
        "on_key_back_color": { "type": "string", "default": "hilited_key_back_color" },
        "on_key_text_color": { "type": "string", "default": "hilited_key_text_color" },
        "preview_back_color": { "type": "string", "default": "key_back_color" },
        "preview_text_color": { "type": "string", "default": "key_text_color" },
        "shadow_color": { "type": "string", "default": "border_color" },
        "root_background": { "type": "string", "default": "back_color" },
        "candidate_background": { "type": "string", "default": "back_color" },
        "keyboard_back_color": { "type": "string", "default": "border_color" },
        "liquid_keyboard_background": { "type": "string", "default": "keyboard_back_color" },
        "text_back_color": { "type": "string", "default": "back_color" },
        "long_text_back_color": { "type": "string", "default": "key_back_color" },
        "clipboard_checkbox_color": { "type": "string", "default": "key_text_color" },
        "clipboard_entry_back_color": { "type": "string" },
        "hilited_clipboard_entry_back_color": { "type": "string" },
        "clipboard_category_back_color": { "type": "string" },
        "clipboard_category_selected_back_color": { "type": "string" },
        "clipboard_category_selected_text_color": { "type": "string" },
        "candidate_view_back_color": { "type": "string" },
        "candidate_virtual_tab_color": { "type": "string" },
        "candidate_virtual_tab_highlight_color": { "type": "string" }
      }
    },
    "preset_color_schemes": {
      "type": "object",
      "patternProperties": {
        "\\w+": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "方案名稱" },
            "author": { "type": "string", "description": "作者資訊" },
            "back_color": { "$ref": "#/definitions/colorValue" },
            "border_color": { "$ref": "#/definitions/colorValue" },
            "candidate_background": { "$ref": "#/definitions/colorValue" },
            "candidate_separator_color": { "$ref": "#/definitions/colorValue" },
            "candidate_text_color": { "$ref": "#/definitions/colorValue" },
            "candidate_view_back_color": { "$ref": "#/definitions/colorValue" },
            "candidate_virtual_tab_color": { "$ref": "#/definitions/colorValue" },
            "candidate_virtual_tab_highlight_color": { "$ref": "#/definitions/colorValue" },
            "clipboard_category_back_color": { "$ref": "#/definitions/colorValue" },
            "clipboard_category_selected_back_color": { "$ref": "#/definitions/colorValue" },
            "clipboard_category_selected_text_color": { "$ref": "#/definitions/colorValue" },
            "clipboard_checkbox_color": { "$ref": "#/definitions/colorValue" },
            "clipboard_entry_back_color": { "$ref": "#/definitions/colorValue" },
            "comment_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_candidate_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_candidate_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_clipboard_entry_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_comment_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_key_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_key_symbol_color": { "$ref": "#/definitions/colorValue" },
            "hilited_key_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_label_color": { "$ref": "#/definitions/colorValue" },
            "hilited_off_key_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_off_key_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_on_key_back_color": { "$ref": "#/definitions/colorValue" },
            "hilited_on_key_text_color": { "$ref": "#/definitions/colorValue" },
            "hilited_text_color": { "$ref": "#/definitions/colorValue" },
            "key_back_color": { "$ref": "#/definitions/colorValue" },
            "key_border_color": { "$ref": "#/definitions/colorValue" },
            "key_symbol_color": { "$ref": "#/definitions/colorValue" },
            "key_text_color": { "$ref": "#/definitions/colorValue" },
            "keyboard_back_color": { "$ref": "#/definitions/colorValue" },
            "label_color": { "$ref": "#/definitions/colorValue" },
            "liquid_keyboard_background": { "$ref": "#/definitions/colorValue" },
            "long_text_back_color": { "$ref": "#/definitions/colorValue" },
            "off_key_back_color": { "$ref": "#/definitions/colorValue" },
            "off_key_text_color": { "$ref": "#/definitions/colorValue" },
            "on_key_back_color": { "$ref": "#/definitions/colorValue" },
            "on_key_text_color": { "$ref": "#/definitions/colorValue" },
            "preview_back_color": { "$ref": "#/definitions/colorValue" },
            "preview_text_color": { "$ref": "#/definitions/colorValue" },
            "root_background": { "$ref": "#/definitions/colorValue" },
            "shadow_color": { "$ref": "#/definitions/colorValue" },
            "text_back_color": { "$ref": "#/definitions/colorValue" },
            "text_color": { "$ref": "#/definitions/colorValue" }
          }
        }
      }
    },
    "liquid_keyboard": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "row": { "type": "integer", "default": 6 },
        "row_land": { "type": "integer", "default": 5 },
        "key_height": { "type": "integer", "default": 40 },
        "key_height_land": { "type": "integer", "default": 40 },
        "single_width": { "type": "integer", "default": 60 },
        "vertical_gap": { "type": "integer", "default": 1 },
        "margin_x": { "type": "number", "default": 5 },
        "fixed_key_bar": {
          "type": "object",
          "properties": {
            "position": {
              "enum": ["top", "bottom", "left", "right", "navbar"],
              "default": "bottom"
            },
            "keys": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "properties": {
                      "click": { "type": "string", "default": "" },
                      "label": { "type": "string", "default": "" },
                      "width": { "type": "number" },
                      "height": { "type": "number" },
                      "margin": {
                        "oneOf": [{ "type": "number" }, { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 4 }]
                      },
                      "padding": {
                        "oneOf": [{ "type": "number" }, { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 4 }]
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "keyboards": {
          "type": "object",
          "patternProperties": {
            "\\w+": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "enum": ["SINGLE", "SYMBOL", "TABS", "HISTORY", "VAR_LENGTH"] },
                "keys": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "properties": {
                          "click": { "type": "string", "default": "" },
                          "label": { "type": "string", "default": "" }
                        }
                      }
                    ]
                  }
                }
              },
              "required": ["type"]
            }
          }
        }
      }
    },
    "preset_keys": {
      "type": "object",
      "patternProperties": {
        "\\w+": {
          "type": "object",
          "properties": {
            "label": { "type": "string", "default": "" },
            "preview": { "type": "string" },
            "send": { "type": "string", "default": "" },
            "command": { "type": "string", "default": "" },
            "option": { "type": "string", "default": "" },
            "select": { "type": "string", "default": "" },
            "toggle": { "type": "string", "default": "" },
            "commit": { "type": "string", "default": "" },
            "text": { "type": "string", "default": "" },
            "shift_lock": { "type": "string", "default": "" },
            "sticky": { "type": "boolean", "default": false },
            "repeatable": { "type": "boolean", "default": false },
            "slide_cursor": { "type": "boolean", "default": false },
            "slide_delete": { "type": "boolean", "default": false },
            "functional": { "type": "boolean", "default": false },
            "states": { "type": "array", "items": { "type": "string" }, "default": [] }
          }
        }
      }
    },
    "preset_keyboards": {
      "type": "object",
      "patternProperties": {
        "\\w+": {
          "type": "object",
          "properties": {
            "__include": { "type": "string" },
            "name": { "type": "string" },
            "author": { "type": "string" },
            "ascii_mode": { "type": "integer", "enum": [0, 1] },
            "reset_ascii_mode": { "type": "boolean" },
            "lock": { "type": "boolean" },
            "label_transform": { "enum": ["none", "uppercase"] },
            "keyboard_height": { "type": "integer" },
            "keyboard_height_land": { "type": "integer" },
            "horizontal_gap": { "type": "integer" },
            "vertical_gap": { "type": "integer" },
            "round_corner": { "type": "number" },
            "key_border": { "type": "integer" },
            "auto_height_index": { "type": "integer" },
            "ascii_keyboard": { "type": "string" },
            "landscape_keyboard": { "type": "string" },
            "landscape_split_percent": { "type": "integer" },
            "import_preset": { "type": "string" },
            "keyboard_padding_top": { "type": "integer" },
            "navbar": { "type": "boolean" },
            "t9_mode": { "type": "boolean" },
            "t9_sidebar_width": { "type": "number" },
            "t9_sidebar_position": { "type": "string" },
            "t9_sidebar_span_rows": { "type": "integer" },
            "t9_sidebar_show_items": { "type": "integer" },
            "t9_sidebar_symbols": { "type": "array", "items": { "type": "string" } },
            "dynamic_mode": { "type": "boolean" },
            "dynamic_original": { "type": "string" },
            "key_text_offset_x": { "type": "number" },
            "key_text_offset_y": { "type": "number" },
            "key_symbol_offset_x": { "type": "number" },
            "key_symbol_offset_y": { "type": "number" },
